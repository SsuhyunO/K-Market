<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.k_market.dao.NoticeDAO">

    <!-- =========================
         공지사항 공통 조건
    ========================= -->
    <sql id="noticeWhere">

        WHERE boardType LIKE 'notice/%'

        <if test="type != null and type != ''">
            AND boardType = CONCAT(
            'notice/',
            #{type}
            )
        </if>

    </sql>


    <!-- =========================
         전체 개수
    ========================= -->
    <select id="getTotalCount"
            resultType="int">

        SELECT COUNT(*)
        FROM board

        <include refid="noticeWhere"/>

    </select>


    <!-- =========================
         목록
    ========================= -->
    <select id="getNoticeList"
            resultType="org.example.k_market.dto.admin.NoticeDTO">

        SELECT
        boardNo,
        memberUid,
        boardType,
        title,
        content,
        fileId,
        createdAt
        FROM board

        <include refid="noticeWhere"/>

        ORDER BY boardNo DESC

        LIMIT #{offset}, #{pageSize}

    </select>


    <!-- =========================
         상세
    ========================= -->
    <select id="getNoticeByNo"
            resultType="org.example.k_market.dto.admin.NoticeDTO">

        SELECT
            boardNo,
            memberUid,
            boardType,
            title,
            content,
            fileId,
            createdAt
        FROM board
        WHERE boardNo = #{boardNo}
          AND boardType LIKE 'notice/%'

    </select>


    <!-- =========================
         등록
    ========================= -->
    <insert id="insertNotice"
            parameterType="org.example.k_market.dto.admin.NoticeDTO"
            useGeneratedKeys="true"
            keyProperty="boardNo">

        INSERT INTO board (
            memberUid,
            boardType,
            title,
            content,
            fileId,
            createdAt
        )
        VALUES (
                   #{memberUid},
                   #{boardType},
                   #{title},
                   #{content},
                   #{fileId},
                   NOW()
               )

    </insert>


    <!-- =========================
         수정
    ========================= -->
    <update id="updateNotice"
            parameterType="org.example.k_market.dto.admin.NoticeDTO">

        UPDATE board
        SET
            boardType = #{boardType},
            title = #{title},
            content = #{content},
            fileId = #{fileId}
        WHERE boardNo = #{boardNo}
          AND boardType LIKE 'notice/%'

    </update>


    <!-- =========================
         단일 삭제
    ========================= -->
    <delete id="deleteNotice">

        DELETE FROM board
        WHERE boardNo = #{boardNo}
          AND boardType LIKE 'notice/%'

    </delete>


    <!-- =========================
         선택 삭제
    ========================= -->
    <delete id="deleteNotices">

        DELETE FROM board
        WHERE boardType LIKE 'notice/%'
        AND boardNo IN

        <foreach collection="boardNoList"
                 item="boardNo"
                 open="("
                 separator=","
                 close=")">
            #{boardNo}
        </foreach>

    </delete>

</mapper>